start: expr

?expr: expr "&" expr   -> and_expr
     | expr "|" expr   -> or_expr
     | expr "==" SIGNED_NUMBER -> eq
     | "C" "(" expr ")" -> cumsum
     | "D" "(" expr ")" -> diff
     | "R" "(" expr ")" -> rise
     | "F" "(" expr ")" -> fall
     | NAME
     | SIGNED_NUMBER
     | "(" expr ")"

%import common.CNAME -> NAME
%import common.SIGNED_NUMBER
%import common.WS
%ignore WS
